function(generate_module_header TARGET_NAME OUTPUT_FILE OUTPUT_RELDIR)
    set(HEADER_FILES ${ARGN})
    set(HEADER_LINES "")
    set(ALIGN_POS 0)

    foreach(HEADER_FILE ${HEADER_FILES})
        file(RELATIVE_PATH REL_HEADER "${CMAKE_CURRENT_SOURCE_DIR}/${OUTPUT_RELDIR}" "${CMAKE_CURRENT_SOURCE_DIR}/${HEADER_FILE}")
        string(LENGTH "#include <${REL_HEADER}>" CURRENT_LEN)
        if(CURRENT_LEN GREATER ALIGN_POS)
            set(ALIGN_POS ${CURRENT_LEN})
        endif()
    endforeach()
    math(EXPR ALIGN_POS "${ALIGN_POS} + 1")

    foreach(HEADER_FILE ${HEADER_FILES})
        file(RELATIVE_PATH REL_HEADER "${CMAKE_CURRENT_SOURCE_DIR}/${OUTPUT_RELDIR}" "${CMAKE_CURRENT_SOURCE_DIR}/${HEADER_FILE}")
        set(INCLUDE_DIRECTIVE "#include <${REL_HEADER}>")
        string(LENGTH "${INCLUDE_DIRECTIVE}" CURRENT_LEN)
        math(EXPR PADDING "${ALIGN_POS} - ${CURRENT_LEN}")

        set(SPACES "")
        if(PADDING GREATER 0)
            foreach(I RANGE 1 ${PADDING})
                string(APPEND SPACES " ")
            endforeach()
        endif()

        string(APPEND HEADER_LINES "${INCLUDE_DIRECTIVE}${SPACES}// IWYU pragma: export\n")
    endforeach()

    get_filename_component(OUTPUT_FILENAME ${OUTPUT_FILE} NAME)
    file(WRITE "${OUTPUT_FILE}" "#pragma once\n\n/// @file ${OUTPUT_FILENAME} Module export header for target `${TARGET_NAME}`.\n/// @note This file is generated by `cmake/gen_module_header.cmake` on configure, don't modify this directly!\n\n${HEADER_LINES}")
endfunction()
