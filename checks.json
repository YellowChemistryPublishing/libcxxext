{
    "checks":  [
        { "name": "check:cppconf", "script": "workflows/cppconf.py", "with": ["-m=${target_arch}", "-p=${run_on}", "-cl=${compiler_name}", "-c=${config}", "-gen=${gen}", "-d=.", "-b=${target_arch}-${run_on}-${compiler_name}-build"] },
        { "name": "check:cppbuild", "script": "workflows/cppbuild.py", "with": ["-m=${target_arch}", "-p=${run_on}", "-cl=${compiler_name}", "-c=${config}", "-gen=${gen}", "-d=.", "-b=${target_arch}-${run_on}-${compiler_name}-build"] },
        { "name": "check:cppfmt", "script": "workflows/cppfmt.py", "with": ["-p=${run_on}", "-f=^(?!(.*build/|rapidcheck/|Catch2/)).*\\.(h|inl|cpp)$"] },
        { "name": "check:cpplint", "script": "workflows/cpplint.py", "with": ["-p=${run_on}", "-cl=${compiler_name}", "-d=.", "-b=${target_arch}-${run_on}-${compiler_name}-build"] },
        { "name": "check:cpptest", "script": "workflows/cpptest.py", "with": ["-p=${run_on}", "-cl=${compiler_name}", "-d=.", "-b=${target_arch}-${run_on}-${compiler_name}-build"] },
        {
            "name":   "check:cppcov",
            "script": "workflows/cppcov.py",
            "with":   ["-p=${run_on}", "-cl=${compiler_name}", "-d=.", "-b=${target_arch}-${run_on}-${compiler_name}-build", "-f=^(build|sys|sys\\.Containers|sys\\.Threading|sys\\.Text)/"]
        },
        {
            "name":   "check:cpppack",
            "script": "workflows/cpppack.py",
            "with":   ["-p=${run_on}", "-cl=${compiler_name}", "-d=.", "-b=${target_arch}-${run_on}-${compiler_name}-build", "-a=${target_arch}-${run_on}-${compiler_name}", "-i=${to_package}"]
        },
        { "name": "check:docgen", "script": "workflows/docgen.py", "with": ["-p=${run_on}"] },
        { "name": "check:pylint", "script": "workflows/pylint.py", "with": ["-p=${run_on}", "-d=./workflows"] }
    ],
    "on_push": [
        {
            "checkset": "x86_64-linux-clang-debug",
            "with":     {"run_on": "linux", "target_arch": "x86_64", "compiler_name": "clang", "config": "Debug", "gen": "Ninja"},
            "runs":     { "check:cppconf": [], "check:cppbuild": ["check:cppconf"], "check:cpplint": ["check:cppconf"], "check:cpptest": ["check:cppbuild"], "check:cppcov": ["check:cpptest"] }
        },
        {
            "checkset": "x86_64-linux-clang-relwithdebinfo",
            "with":     {"run_on": "linux", "target_arch": "x86_64", "compiler_name": "clang", "config": "RelWithDebInfo", "gen": "Ninja", "to_package": "install"},
            "runs":     { "check:cppconf": [], "check:cppbuild": ["check:cppconf"], "check:cpppack": ["check:cppbuild"] }
        },
        {
            "checkset": "x86_64-linux-gcc-debug",
            "with":     {"run_on": "linux", "target_arch": "x86_64", "compiler_name": "gcc", "config": "Debug", "gen": "Unix Makefiles"},
            "runs":     { "check:cppconf": [], "check:cppbuild": ["check:cppconf"], "check:cpplint": ["check:cppconf"], "check:cpptest": ["check:cppbuild"], "check:cppcov": ["check:cpptest"] }
        },
        {
            "checkset": "x86_64-linux-gcc-relwithdebinfo",
            "with":     {"run_on": "linux", "target_arch": "x86_64", "compiler_name": "gcc", "config": "Debug", "gen": "Unix Makefiles", "to_package": "install"},
            "runs":     { "check:cppconf": [], "check:cppbuild": ["check:cppconf"], "check:cpplint": ["check:cppconf"], "check:cpptest": ["check:cppbuild"], "check:cppcov": ["check:cpptest"], "check:cpppack": ["check:cppbuild"] }
        },
        {
            "checkset": "i686-linux-clang-debug",
            "with":     {"run_on": "linux", "target_arch": "i686", "compiler_name": "clang", "config": "Debug", "gen": "Ninja"},
            "runs":     { "check:cppconf": [], "check:cppbuild": ["check:cppconf"], "check:cpplint": ["check:cppconf"] }
        },
        {
            "checkset": "i686-linux-clang-relwithdebinfo",
            "with":     {"run_on": "linux", "target_arch": "i686", "compiler_name": "clang", "config": "RelWithDebInfo", "gen": "Ninja", "to_package": "install"},
            "runs":     { "check:cppconf": [], "check:cppbuild": ["check:cppconf"], "check:cpppack": ["check:cppbuild"] }
