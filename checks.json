            "with":     {"run_on": "win32", "target_arch": "i686", "compiler_name": "msvc", "config": "Debug", "gen": "Visual Studio 17 2022"},
            "runs":     { "check:cppconf": [], "check:cppbuild": ["check:cppconf"], "check:cpplint": ["check:cppbuild"], "check:cpptest": ["check:cppbuild"] }
        },
        {
            "checkset": "i686-win32-msvc-relwithdebinfo",
            "with":     {"run_on": "win32", "target_arch": "i686", "compiler_name": "msvc", "config": "RelWithDebInfo", "gen": "Visual Studio 17 2022", "to_package": "install"},
